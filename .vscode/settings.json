{
  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.tabSize": 2,
  "editor.rulers": [120],

  // ── C# ────────────────────────────────────────────────────────────────────
  "[csharp]": {
    "editor.defaultFormatter": "ms-dotnettools.csharp",
    "editor.tabSize": 4
  },
  "dotnet.defaultSolution": "TechSolve.sln",
  "omnisharp.enableRoslynAnalyzers": true,
  "omnisharp.enableEditorConfigSupport": true,

  // ── TypeScript / Angular ──────────────────────────────────────────────────
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "typescript.tsdk": "TechSolve.UI/clientApp/node_modules/typescript/lib",
  "angular.enable-strict-mode-prompt": false,

  // ── File associations ────────────────────────────────────────────────────
  "files.associations": {
    "*.csproj": "xml",
    "*.sln": "text"
  },

  // ── Exclude noisy folders from Explorer ──────────────────────────────────
  "files.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/node_modules": true,
    "**/.angular": true,
    "**/dist": true
  },

  // ── Search exclusions ────────────────────────────────────────────────────
  "search.exclude": {
    "**/bin": true,
    "**/obj": true,
    "**/node_modules": true,
    "**/.angular": true,
    "**/dist": true
  },

  // ── Terminal ─────────────────────────────────────────────────────────────
  "terminal.integrated.defaultProfile.windows": "Command Prompt",
  "terminal.integrated.splitTerminal": true
}
